
# PostgreSQL — your own database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/sufisciencecenter

# Stripe — get from: Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_live_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# App URL — your production domain (used for Stripe redirect fallback)
NEXT_PUBLIC_APP_URL=https://sufisciencecenter.org

# Admin credentials — used for the admin dashboard login
ADMIN_EMAIL=admin@sufisciencecenter.org
ADMIN_PASSWORD=change_this_strong_password

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long
