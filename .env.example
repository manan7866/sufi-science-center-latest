
# PostgreSQL — your own database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/sufisciencecenter

# Stripe — get from: Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_live_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# App URL — your production domain (used for Stripe redirect fallback)
NEXT_PUBLIC_APP_URL=https://sufisciencecenter.org

# Admin credentials — used for the admin dashboard login
ADMIN_EMAIL=admin@sufisciencecenter.org
ADMIN_PASSWORD=change_this_strong_password

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long

# Cloudinary — for avatar uploads (free tier: https://cloudinary.com/users/register/free)
# Get these from: Cloudinary Dashboard > Settings > Access Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_UPLOAD_PRESET=ssc_profiles

# Resend — for email sending (OTP verification)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM="Sufi Science Center <info@sufisciencecenter.info>"

# YouTube API — for fetching video data from YouTube channel
# Get from: Google Cloud Console > APIs & Services > Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here
