  registrationDeadline  DateTime? @map("registration_deadline")
  isActive              Boolean   @default(false) @map("is_active")
  isOpenForSubmissions  Boolean   @default(false) @map("is_open_for_submissions")
  isOpenForRegistration Boolean   @default(false) @map("is_open_for_registration")
  maxSubmissions        Int?      @map("max_submissions")
