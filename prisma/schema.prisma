  @@index([saintId])
  @@index([lineageId])
  @@map("saint_lineages")
}

model Relationship {
  id               String    @id @default(uuid())
  entityTypeA      String    @map("entity_type_a")
  entityIdA        String    @map("entity_id_a")
  entityTypeB      String    @map("entity_type_b")
  entityIdB        String    @map("entity_id_b")
  relationshipType String    @map("relationship_type")
  metadata         Json?
  influenceTypeId  String?   @map("influence_type_id")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([relationshipType])
  @@index([entityTypeA, entityIdA])
  @@index([entityTypeB, entityIdB])
  @@map("relationships")
}

model Assessment {
  id          String               @id @default(uuid())
  slug        String               @unique
  title       String
  description String?
  version     Int                  @default(1)
  isActive    Boolean              @default(true) @map("is_active")
  deletedAt   DateTime?            @map("deleted_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  questions   AssessmentQuestion[]
  results     AssessmentResult[]

  @@index([slug])
  @@map("assessments")
}

model AssessmentQuestion {
  id           String     @id @default(uuid())
  assessmentId String     @map("assessment_id")
  dimension    String
  questionText String     @map("question_text")
  weight       Float      @default(1.0)
  orderIndex   Int        @map("order_index")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([dimension])
  @@map("assessment_questions")
}

model AssessmentResult {
  id           String     @id @default(uuid())
  assessmentId String     @map("assessment_id")
  resultJson   Json       @map("result_json")
  createdAt    DateTime   @default(now()) @map("created_at")
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("assessment_results")
}

model Practice {
