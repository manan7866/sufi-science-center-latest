generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  permissions  String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String?
  googleId   String?   @unique @map("google_id")
  avatarUrl  String?   @map("avatar_url")
  bio        String?
  location   String?
  phone      String?
  isAdmin    Boolean   @default(false) @map("is_admin")
  isVerified Boolean   @default(false) @map("is_verified")
  otp        String?
  otpExpiry  DateTime? @map("otp_expiry")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  reflections ReflectionEntry[]

  @@index([email])
  @@index([isVerified])
  @@index([isAdmin])
  @@index([googleId])
  @@map("users")
}

model PortalSession {
  id               String                @id @default(uuid())
  sessionToken     String                @unique @default(uuid()) @map("session_token")
  displayName      String?               @map("display_name")
  assessmentStage  String                @default("Not Yet Assessed") @map("assessment_stage")
  completedModules String[]              @default([]) @map("completed_modules")
  currentFocus     String?               @map("current_focus")
  lastActivityAt   DateTime              @default(now()) @map("last_activity_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  membership       MembershipEnrollment?
  activityEvents   ActivityEvent[]
  profile          PortalProfile?
  reflections      ReflectionEntry[]
  supportTickets   SupportTicket[]
  surahViews       SurahView[]

  @@index([sessionToken])
  @@map("portal_sessions")
}

model PortalProfile {
  id           String        @id @default(uuid())
  sessionToken String        @unique @map("session_token")
  fullName     String        @default("") @map("full_name")
  displayName  String        @default("") @map("display_name")
  location     String        @default("")
  bio          String        @default("")
  interests    String[]      @default([])
  avatarUrl    String        @default("") @map("avatar_url")
  email        String        @default("")
  phone        String        @default("")
  addressLine1 String        @default("") @map("address_line1")
  addressLine2 String        @default("") @map("address_line2")
  city         String        @default("")
  country      String        @default("")
  postalCode   String        @default("") @map("postal_code")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  session      PortalSession @relation(fields: [sessionToken], references: [sessionToken], onDelete: Cascade)

  @@index([sessionToken])
  @@map("portal_profiles")
}

model MembershipEnrollment {
  id           String        @id @default(uuid())
  sessionToken String        @unique @map("session_token")
  tier         String        @default("seeker")
  status       String        @default("active")
  appliedAt    DateTime      @default(now()) @map("applied_at")
  activatedAt  DateTime      @default(now()) @map("activated_at")
  cancelledAt  DateTime?     @map("cancelled_at")
  notes        String        @default("")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  session      PortalSession @relation(fields: [sessionToken], references: [sessionToken], onDelete: Cascade)

  @@index([sessionToken])
  @@map("membership_enrollments")
}

model SurahView {
  id           String        @id @default(uuid())
  sessionToken String        @map("session_token")
  surahNumber  Int           @map("surah_number")
  viewedAt     DateTime      @default(now()) @map("viewed_at")
  session      PortalSession @relation(fields: [sessionToken], references: [sessionToken], onDelete: Cascade)

  @@unique([sessionToken, surahNumber])
  @@index([sessionToken])
  @@index([surahNumber])
  @@map("surah_views")
}

model ReflectionEntry {
  id             String   @id @default(uuid())
  sessionToken   String?  @map("session_token")
  userId         String?  @map("user_id")

  surahNumber    Int      @map("surah_number")
  reflectionText String   @map("reflection_text")

  isApproved     Boolean  @default(false) @map("is_approved")
  approvedAt     DateTime? @map("approved_at")
  isRejected     Boolean  @default(false)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  session        PortalSession? @relation(fields: [sessionToken], references: [sessionToken], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@index([userId])
  @@index([surahNumber])

  @@map("reflection_journal")
}

model ActivityEvent {
  id            String        @id @default(uuid())
  sessionToken  String        @map("session_token")
  eventType     String        @default("") @map("event_type")
  eventLabel    String        @default("") @map("event_label")
  eventMetadata Json?         @default("{}") @map("event_metadata")
  occurredAt    DateTime      @default(now()) @map("occurred_at")
  session       PortalSession @relation(fields: [sessionToken], references: [sessionToken], onDelete: Cascade)

  @@index([sessionToken])
  @@index([occurredAt])
  @@map("portal_activity_events")
}

model SupportTicket {
  id           String               @id @default(uuid())
  sessionToken String               @map("session_token")
  ticketNumber String               @unique @map("ticket_number")
  subject      String
  description  String
  category     String               @default("general")
  priority     String               @default("medium")
  status       String               @default("open")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  replies      SupportTicketReply[]
  session      PortalSession        @relation(fields: [sessionToken], references: [sessionToken], onDelete: Cascade)

  @@index([sessionToken])
  @@map("support_tickets")
}

model SupportTicketReply {
  id         String        @id @default(uuid())
  ticketId   String        @map("ticket_id")
  authorType String        @default("admin") @map("author_type")
  authorName String        @default("SSC Support Team") @map("author_name")
  body       String
  createdAt  DateTime      @default(now()) @map("created_at")
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_ticket_replies")
}

model Donation {
  id                    String    @id @default(uuid())
  donorId               String?   @map("donor_id")
  donorName             String    @map("donor_name")
  donorEmail            String    @map("donor_email")
  amount                Float
  currency              String    @default("usd")
  frequency             String    @default("one_time")
  status                String    @default("pending")
  processor             String?
  processingEntity      String?   @map("processing_entity")
  transactionId         String    @unique @map("transaction_id")
  stripeSessionId       String?   @map("stripe_session_id")
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  receiptUrl            String?   @map("receipt_url")
  message               String?
  completedAt           DateTime? @map("completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  donor                 Donor?    @relation(fields: [donorId], references: [id])

  @@index([donorId])
  @@index([donorEmail])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("donations")
}

model Donor {
  id                String    @id @default(uuid())
  fullName           String    @map("full_name")
  email             String    @map("email")
  phone             String?
  country           String?
  addressLine1       String?   @map("address_line1")
  city              String?
  state             String?
  postalCode         String?   @map("postal_code")
  anonymous         Boolean   @default(false) @map("anonymous")
  stripeCustomerId   String?   @map("stripe_customer_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  donations         Donation[]
  subscriptions     DonationSubscription[]

  @@unique([email])
  @@index([stripeCustomerId])
  @@map("donors")
}

model DonationSubscription {
  id                   String    @id @default(uuid())
  donorId              String    @map("donor_id")
  amountCents          Int       @map("amount_cents")
  currency             String    @default("usd") @map("currency")
  interval             String    @default("month") @map("interval")
  status              String    @default("pending") @map("status")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripePriceId        String?   @map("stripe_price_id")
  currentPeriodStart   DateTime?  @map("current_period_start") @db.Date
  currentPeriodEnd    DateTime?  @map("current_period_end") @db.Date
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt         DateTime?  @map("canceled_at") @db.Date
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  donor              Donor     @relation(fields: [donorId], references: [id])

  @@index([donorId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@map("donation_subscriptions")
}

model PaymentEvent {
  id          String   @id @default(uuid())
  stripeEventId String   @unique @map("stripe_event_id")
  eventType   String   @map("event_type")
  objectId   String?  @map("object_id")
  payload    Json?    @default("{}") @map("payload")
  processed  Boolean  @default(false) @map("processed")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([processed])
  @@map("payment_events")
}

model MembershipApplication {
  id                 String    @id @default(uuid())
  userId             String?   @map("user_id")
  membershipType     String    @map("membership_type")
  status             String    @default("pending")
  fullName           String    @map("full_name")
  displayName        String    @default("") @map("display_name")
  email              String
  location           String    @default("")
  affiliation        String    @default("")
  areasOfStudy       String[]  @default([]) @map("areas_of_study")
  bio                String    @default("")
  statement          String    @default("")
  linkedPublications String[]  @default([]) @map("linked_publications")
  academicFocus      String?   @map("academic_focus")
  researchInterest   String?   @map("research_interest")
  yearsOfEngagement  String?   @map("years_of_engagement")
  leadershipRoles    String?   @map("leadership_roles")
  publicationsList   String?   @map("publications_list")
  referenceContact   String?   @map("reference_contact")
  reviewNotes        String?   @map("review_notes")
  reviewedAt         DateTime? @map("reviewed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@index([userId])
  @@map("membership_applications")
}

model VolunteerApplication {
  id             String    @id @default(uuid())
  userId         String?   @map("user_id")
  roleType       String    @map("role_type")
  fullName       String    @map("full_name")
  email          String
  skillsText     String    @map("skills_text")
  motivationText String    @map("motivation_text")
  status         String    @default("pending")
  reviewNotes    String?   @map("review_notes")
  reviewedAt     DateTime? @map("reviewed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@index([userId])
  @@map("volunteer_applications")
}

model PathwayApplication {
  id          String    @id @default(uuid())
  fullName    String    @map("full_name")
  email       String
  status      String    @default("pending")
  reviewNotes String?   @map("review_notes")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@map("pathway_applications")
}

model MentorshipApplication {
  id                           String    @id @default(uuid())
  userId                       String?   @map("user_id")
  programId                    String?   @map("program_id")
  fullName                     String    @map("full_name")
  email                        String
  phone                        String?
  backgroundSummary            String?   @map("background_summary")
  spiritualGoals               String?   @map("spiritual_goals")
  relevantExperience           String?   @map("relevant_experience")
  whyThisProgram               String?   @map("why_this_program")
  commitmentLevel              String?   @map("commitment_level")
  availability                 String?
  previousMentorshipExperience String?   @map("previous_mentorship_experience")
  status                       String    @default("pending")
  reviewNotes                  String?   @map("review_notes")
  reviewedAt                   DateTime? @map("reviewed_at")
  interviewScheduledFor        DateTime? @map("interview_scheduled_for")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@index([userId])
  @@map("mentorship_applications")
}

model CollaborationProposal {
  id                String    @id @default(uuid())
  userId            String?   @map("user_id")
  organizationType  String    @map("organization_type")
  organizationName  String    @map("organization_name")
  contactName       String    @map("contact_name")
  contactEmail      String    @map("contact_email")
  contactPhone      String?   @map("contact_phone")
  collaborationType String    @map("collaboration_type")
  proposalSummary   String    @map("proposal_summary")
  proposalDetails   String    @map("proposal_details")
  scope             String
  timeline          String
  status            String    @default("pending")
  reviewNotes       String?   @map("review_notes")
  reviewedAt        DateTime? @map("reviewed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([contactEmail])
  @@index([userId])
  @@map("collaboration_proposals")
}

model ConferenceSubmission {
  id                   String    @id @default(uuid())
  userId               String?   @map("user_id")
  conferenceId         String?   @map("conference_id")
  trackingCode         String    @unique @map("tracking_code")
  submissionType       String    @map("submission_type")
  title                String
  abstract             String
  keywords             String?
  presenterName        String    @map("presenter_name")
  presenterEmail       String    @map("presenter_email")
  presenterAffiliation String    @map("presenter_affiliation")
  presenterBio         String    @map("presenter_bio")
  coPresenters         Json      @default("[]") @map("co_presenters")
  fileName             String?   @map("file_name")
  fileSizeBytes        Int?      @map("file_size_bytes")
  status               String    @default("submitted")
  adminNotes           String?   @map("admin_notes")
  reviewerDecision     String?   @map("reviewer_decision")
  reviewedBy           String?   @map("reviewed_by")
  reviewedAt           DateTime?  @map("reviewed_at")
  submittedAt         DateTime  @default(now()) @map("submitted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  conference           ConferenceEvent? @relation(fields: [conferenceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([presenterEmail])
  @@index([trackingCode])
  @@index([userId])
  @@index([conferenceId])
  @@map("conference_submissions")
}

model MediaTrack {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  viewCount Int      @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("media_tracks")
}

model Saint {
  id            String         @id @default(uuid())
  slug          String         @unique @default("")
  name          String
  birthYear     Int?           @map("birth_year")
  deathYear     Int?           @map("death_year")
  biography     String?
  shortSummary  String?        @map("short_summary")
  region        String?
  isFounder     Boolean        @default(false) @map("is_founder")
  deletedAt     DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  saintLineages SaintLineage[]
  saintThemes   SaintTheme[]

  @@index([slug])
  @@index([birthYear])
  @@index([deathYear])
  @@index([region])
  @@map("saints_cms")
}

model Dialogue {
  id                   String    @id @default(uuid())
  slug                 String    @unique @default("untitled")
  title                String
  subtitle             String?
  description          String?
  type                 String?
  host                 String?
  isPublished          Boolean   @default(false) @map("is_published")
  publishedAt          DateTime? @map("published_at")
  viewCount            Int       @default(0) @map("view_count")
  difficultyLevel      String?   @map("difficulty_level")
  totalEpisodes        Int       @default(0) @map("total_episodes")
  totalDurationMinutes Int       @default(0) @map("total_duration_minutes")
  participants         String[]  @default([])
  isFeatured           Boolean   @default(false) @map("is_featured")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  episodes             Episode[]

  @@index([slug])
  @@index([isPublished])
  @@index([publishedAt])
  @@map("dialogues_cms")
}

model Episode {
  id              String   @id @default(uuid())
  seriesId        String   @map("series_id")
  episodeNumber   Int      @map("episode_number")
  slug            String   @unique
  title           String
  description     String
  transcript      String?
  keyQuestions    Json     @default("[]") @map("key_questions")
  keyInsights     Json     @default("[]") @map("key_insights")
  participants    String[] @default([])
  durationMinutes Int?     @map("duration_minutes")
  videoUrl        String?  @map("video_url")
  audioUrl        String?  @map("audio_url")
  publishedAt     DateTime @default(now()) @map("published_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  series          Dialogue @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, episodeNumber])
  @@unique([seriesId, slug])
  @@index([seriesId])
  @@index([publishedAt])
  @@map("series_episodes")
}

model HardTalkSession {
  id                  String   @id @default(uuid())
  slug                String   @unique
  title               String
  description         String
  transcript          String?
  participants        String[] @default([])
  videoUrl            String?  @map("video_url")
  audioUrl            String?  @map("audio_url")
  controversialPoints Json     @default("[]") @map("controversial_points")
  citations           Json     @default("[]")
  themes              String[] @default([])
  publishedAt         DateTime @default(now()) @map("published_at")
  featured            Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([publishedAt])
  @@map("hard_talk_sessions")
}

model PracticeProfile {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  description     String
  methodology     String?
  steps           String[] @default([])
  practiceType    String   @map("practice_type")
  durationMinutes Int?     @map("duration_minutes")
  difficultyLevel String?  @map("difficulty_level")
  relatedSaints   String[] @default([]) @map("related_saints")
  themes          String[] @default([])
  tags            String[] @default([])
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([practiceType])
  @@map("practices_profiles")
}

model InspiringInterview {
  id                     String   @id @default(uuid())
  slug                   String   @unique
  title                  String
  description            String
  transcript             String?
  intervieweeName        String   @map("interviewee_name")
  intervieweeAffiliation String?  @map("interviewee_affiliation")
  intervieweeBio         String?  @map("interviewee_bio")
  videoUrl               String?  @map("video_url")
  audioUrl               String?  @map("audio_url")
  keyClips               Json     @default("[]") @map("key_clips")
  themes                 String[] @default([])
  relatedSaints          String[] @default([]) @map("related_saints")
  publishedAt            DateTime @default(now()) @map("published_at")
  featured               Boolean  @default(false)
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([publishedAt])
  @@map("inspiring_interviews")
}

model InterviewApplication {
  id           String    @id @default(uuid())
  userId       String?   @map("user_id")
  name         String
  email        String
  affiliation  String?
  fieldOfWork  String    @map("field_of_work")
  summary      String
  themes       String[]  @default([])
  links        Json      @default("[]")
  availability Json      @default("{}")
  status       String    @default("pending")
  adminNotes   String?   @map("admin_notes")
  scheduledAt  DateTime? @map("scheduled_at")
  scheduledTime String?  @map("scheduled_time")
  videoLink   String?   @map("video_link")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@index([userId])
  @@map("interview_applications")
}

model ResearchPaper {
  id            String   @id @default(uuid())
  title         String
  abstract      String?
  authors       Json     @default("[]")
  publishedYear Int?     @map("published_year")
  journal       String?
  doi           String?
  url           String?
  isFeatured    Boolean  @default(false) @map("is_featured")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("research_papers_cms")
}

model SacredKalam {
  id        String   @id @default(uuid())
  slug      String   @unique @default("")
  title     String
  viewCount Int      @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("sacred_kalam")
}

model SurahCommentary {
  id                  String   @id @default(uuid())
  surahNumber         Int      @unique @map("surah_number")
  arabicName          String   @default("") @map("arabic_name")
  englishName         String   @default("") @map("english_name")
  revelationType      String   @default("meccan") @map("revelation_type")
  coreTheme           String   @default("") @map("core_theme")
  structuralAxis      String?  @map("structural_axis")
  sufiReflection      String?  @map("sufi_reflection")
  interfaithResonance String?  @map("interfaith_resonance")
  hasInterfaithNote   Boolean  @default(false) @map("has_interfaith_note")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([surahNumber])
  @@map("surah_commentary")
}

model UserRoleGrant {
  id          String    @id @default(uuid())
  email       String    @unique
  grantedRole String    @default("seeker") @map("granted_role")
  permissions Json      @default("{}")
  notes       String?
  isBlocked   Boolean   @default(false) @map("is_blocked")
  blockReason String?   @map("block_reason")
  blockedAt   DateTime? @map("blocked_at")
  grantedAt   DateTime  @default(now()) @map("granted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("user_role_grants")
}

model Lineage {
  id              String         @id @default(uuid())
  slug            String         @unique
  name            String
  description     String?
  parentLineageId String?        @map("parent_lineage_id")
  level           Int            @default(0)
  displayOrder    Int            @default(0) @map("display_order")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  parentLineage   Lineage?       @relation("LineageHierarchy", fields: [parentLineageId], references: [id])
  childLineages   Lineage[]      @relation("LineageHierarchy")
  saints          SaintLineage[]

  @@index([slug])
  @@index([parentLineageId])
  @@map("lineages")
}

model Theme {
  id                 String       @id @default(uuid())
  slug               String       @unique
  name               String
  description        String?
  category           String       @default("interdisciplinary")
  conceptualClusters String[]     @default([]) @map("conceptual_clusters")
  displayOrder      Int          @default(0) @map("display_order")
  deletedAt         DateTime?    @map("deleted_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  paperThemes       PaperTheme[]
  saintThemes       SaintTheme[]

  @@index([slug])
  @@index([category])
  @@map("themes")
}

model Region {
  id             String    @id @default(uuid())
  name           String
  parentRegionId String?   @map("parent_region_id")
  level          Int       @default(0)
  slug           String    @unique
  description    String?
  displayOrder   Int       @default(0) @map("display_order")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  parentRegion   Region?   @relation("RegionHierarchy", fields: [parentRegionId], references: [id])
  childRegions   Region[]  @relation("RegionHierarchy")

  @@index([parentRegionId])
  @@index([level])
  @@map("regions")
}

model HistoricalPeriod {
