}

model SaintTheme {
  id        String   @id @default(uuid())
  saintId   String   @map("saint_id")
  themeId   String   @map("theme_id")
  createdAt DateTime @default(now()) @map("created_at")
  saint     Saint    @relation(fields: [saintId], references: [id])
  theme     Theme    @relation(fields: [themeId], references: [id])

  @@unique([saintId, themeId])
  @@index([saintId])
  @@index([themeId])
  @@map("saint_themes")
}

model PaperTheme {
  id        String   @id @default(uuid())
  paperId   String   @map("paper_id")
  themeId   String   @map("theme_id")
  createdAt DateTime @default(now()) @map("created_at")
  theme     Theme    @relation(fields: [themeId], references: [id])

  @@unique([paperId, themeId])
  @@index([paperId])
  @@index([themeId])
  @@map("paper_themes")
}

model SaintLineage {
  id        String   @id @default(uuid())
  saintId   String   @map("saint_id")
  lineageId String   @map("lineage_id")
  role      String?
  createdAt DateTime @default(now()) @map("created_at")
  lineage   Lineage  @relation(fields: [lineageId], references: [id])
  saint     Saint    @relation(fields: [saintId], references: [id])

